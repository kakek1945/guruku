# Runtime database URL.
# Local: direct local Postgres URL
# Vercel + Supabase: use the Supabase transaction pooler URL (serverless/pooler, usually port 6543)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/guruku

# Migration database URL.
# Use the direct connection string for migrations (Supabase direct connection, usually port 5432).
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/guruku

# Better Auth secret for signing sessions and tokens.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Public app URL used by Better Auth callbacks and cookie handling.
# Local example:
BETTER_AUTH_URL=http://localhost:3000

# Optional overrides.
# Leave empty on Vercel if the app uses the same domain for frontend and API/auth routes.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_AUTH_BASE_URL=
